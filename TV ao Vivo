<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TV Voz de Brasília - TV Ao Vivo</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { 
            margin: 0; 
            padding: 20px; 
            background: #0a0e27; 
            color: white; 
            font-family: 'Inter', sans-serif; 
        }
        .container { max-width: 1200px; margin: 0 auto; }
        
        .video-wrapper {
            position: relative;
            padding-bottom: 56.25%;
            height: 0;
            background: #000;
            border-radius: 16px;
            overflow: hidden;
            margin-bottom: 30px;
        }
        .video-wrapper iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
        }
        
        .filtros {
            display: flex;
            gap: 10px;
            margin-bottom: 25px;
            flex-wrap: wrap;
        }
        .filtro-btn {
            padding: 10px 20px;
            border: 2px solid #fbbf24;
            background: transparent;
            color: #fbbf24;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s;
        }
        .filtro-btn:hover {
            background: rgba(251, 191, 36, 0.2);
        }
        .filtro-btn.ativo {
            background: #fbbf24;
            color: #0a0e27;
        }
        .filtro-btn.destaque {
            background: #fbbf24;
            color: #0a0e27;
            font-size: 16px;
            padding: 12px 24px;
        }
        
        .lista-videos {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 15px;
        }
        .video-card {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 12px;
            padding: 12px;
            cursor: pointer;
            display: flex;
            gap: 12px;
            transition: all 0.3s;
        }
        .video-card:hover {
            background: rgba(251, 191, 36, 0.1);
            border-color: #fbbf24;
            transform: translateX(5px);
        }
        .video-card.ativo {
            background: rgba(251, 191, 36, 0.2);
            border-color: #fbbf24;
        }
        .video-card img {
            width: 140px;
            height: 80px;
            object-fit: cover;
            border-radius: 8px;
        }
        .video-card h3 {
            margin: 0 0 8px 0;
            font-size: 14px;
            font-weight: 600;
        }
        .video-card p {
            margin: 0;
            font-size: 12px;
            color: #94a3b8;
        }
        .categoria-badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 4px;
            font-size: 10px;
            font-weight: 700;
            margin-bottom: 6px;
            text-transform: uppercase;
        }
        .cat-empresarial { background: #10b981; color: white; }
        .cat-politica { background: #3b82f6; color: white; }
        .cat-internacional { background: #8b5cf6; color: white; }
        
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        .logo {
            display: flex;
            align-items: center;
            gap: 15px;
        }
        .logo-icon { overflow:hidden;
            width: 50px;
            height: 50px;
            background: linear-gradient(135deg, #fbbf24, #d4af37);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
        }
        .btn-voltar {
            padding: 10px 20px;
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.3);
            color: white;
            border-radius: 8px;
            text-decoration: none;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <div class="logo">
                <div class="logo-icon"><img src="./logo-voznews-oficial.png" alt="VOZNEWS VISIBILIDADE" style="width:100%;height:100%;object-fit:contain"></div>
                <div>
                    <h1 style="margin:0; font-size:24px;">TV VOZ DE BRASÍLIA</h1>
                    <p style="margin:0; color:#fbbf24; font-size:12px;">40 ANOS DE HISTÓRIA</p>
                </div>
            </div>
            <a href="index.html" class="btn-voltar">← Voltar ao Site</a>
        </div>

        <div class="video-wrapper">
            <div id="player"></div>
        </div>

        <div class="filtros">
            <button class="filtro-btn destaque" onclick="filtrar('empresarial')">🏢 EMPRESARIAL</button>
            <button class="filtro-btn" onclick="filtrar('politica')">🏛️ Política</button>
            <button class="filtro-btn" onclick="filtrar('internacional')">🌍 Internacional</button>
            <button class="filtro-btn" onclick="filtrar('todas')">Todas</button>
        </div>

        <div class="lista-videos" id="playlist"></div>
    </div>

    <script>
        const videos = [
            { id: '5QWMLQjrV4c', titulo: 'Instituto de Medicina', cat: 'empresarial' },
            { id: 'b5t8TEEJdiU', titulo: 'Andrezza Bentes - Kumon', cat: 'empresarial' },
            { id: 'tB84ssWNLYg', titulo: 'Thiago Manzoni', cat: 'empresarial' },
            { id: 'mFX7ZEVbjrI', titulo: 'Igor Popov', cat: 'politica' },
            { id: 'rkLjp5Loue8', titulo: 'Senador Dr. Hiran', cat: 'politica' },
            { id: 'SWgHKS_i1UM', titulo: 'Representante ONU', cat: 'politica' },
            { id: '8FBjQfoH8o8', titulo: 'Embaixadora do Egito', cat: 'internacional' }
        ];

        let categoriaAtual = 'empresarial';
        let indiceAtual = 0;
        let player;
        let videosFiltrados = [];

        const tag = document.createElement('script');
        tag.src = 'https://www.youtube.com/iframe_api';
        document.head.appendChild(tag);

        function onYouTubeIframeAPIReady() {
            filtrar('empresarial');
        }

        function filtrar(categoria) {
            categoriaAtual = categoria;
            
            document.querySelectorAll('.filtro-btn').forEach(btn => btn.classList.remove('ativo'));
            event.target.classList.add('ativo');

            if (categoria === 'todas') {
                videosFiltrados = [...videos];
            } else {
                videosFiltrados = videos.filter(v => v.cat === categoria);
            }

            indiceAtual = 0;
            if (videosFiltrados.length > 0) {
                if (!player) {
                    player = new YT.Player('player', {
                        height: '100%',
                        width: '100%',
                        videoId: videosFiltrados[0].id,
                        playerVars: { 'autoplay': 1, 'controls': 1 },
                        events: {
                            'onReady': () => player.playVideo(),
                            'onStateChange': (e) => {
                                if (e.data === YT.PlayerState.ENDED) {
                                    indiceAtual = (indiceAtual + 1) % videosFiltrados.length;
                                    player.loadVideoById(videosFiltrados[indiceAtual].id);
                                    renderizar();
                                }
                            }
                        }
                    });
                } else {
                    player.loadVideoById(videosFiltrados[0].id);
                }
            }
            renderizar();
        }

        function renderizar() {
            const container = document.getElementById('playlist');
            const badges = {
                'empresarial': '<span class="categoria-badge cat-empresarial">Empresarial</span>',
                'politica': '<span class="categoria-badge cat-politica">Política</span>',
                'internacional': '<span class="categoria-badge cat-internacional">Internacional</span>'
            };

            container.innerHTML = videosFiltrados.map((v, i) => `
                <div class="video-card ${i === indiceAtual ? 'ativo' : ''}" onclick="tocar(${i})">
                    <img src="https://img.youtube.com/vi/${v.id}/mqdefault.jpg">
                    <div>
                        ${badges[v.cat]}
                        <h3>${v.titulo}</h3>
                        <p>${i === indiceAtual ? '▶ Tocando agora' : 'Clique para assistir'}</p>
                    </div>
                </div>
            `).join('');
        }

        function tocar(index) {
            indiceAtual = index;
            player.loadVideoById(videosFiltrados[indiceAtual].id);
            renderizar();
        }
    </script>
</body>
</html>
