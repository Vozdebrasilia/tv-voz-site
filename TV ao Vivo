<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TV Voz de Brasília - TV Ao Vivo</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { 
            margin: 0; 
            padding: 0; 
            background: #0a0e27; 
            color: white; 
            font-family: 'Inter', sans-serif; 
        }
        .container { max-width: 1200px; margin: 0 auto; padding: 20px; }
        
        .video-container {
            position: relative;
            width: 100%;
            padding-bottom: 56.25%;
            background: #000;
            border-radius: 16px;
            overflow: hidden;
            margin-bottom: 30px;
        }
        .video-container iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: none;
        }
        
        .filters {
            display: flex;
            gap: 12px;
            margin-bottom: 30px;
            flex-wrap: wrap;
        }
        .filter-btn {
            padding: 12px 24px;
            border: 2px solid #fbbf24;
            background: transparent;
            color: #fbbf24;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            font-size: 14px;
            transition: all 0.3s;
        }
        .filter-btn:hover {
            background: rgba(251, 191, 36, 0.2);
        }
        .filter-btn.active {
            background: #fbbf24;
            color: #0a0e27;
        }
        .filter-btn.destaque {
            background: #fbbf24;
            color: #0a0e27;
            font-size: 16px;
            padding: 14px 28px;
        }
        
        .playlist {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 16px;
        }
        .video-item {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 12px;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            gap: 12px;
        }
        .video-item:hover {
            background: rgba(251, 191, 36, 0.1);
            border-color: #fbbf24;
            transform: translateX(4px);
        }
        .video-item.active {
            background: rgba(251, 191, 36, 0.2);
            border-color: #fbbf24;
        }
        .video-item img {
            width: 160px;
            height: 90px;
            object-fit: cover;
            border-radius: 8px;
        }
        .video-item h3 {
            margin: 0 0 8px 0;
            font-size: 15px;
            font-weight: 600;
        }
        .video-item p {
            margin: 0;
            font-size: 13px;
            color: #94a3b8;
        }
        .badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 4px;
            font-size: 11px;
            font-weight: 600;
            margin-bottom: 8px;
        }
        .badge-empresarial { background: #10b981; color: white; }
        .badge-politica { background: #3b82f6; color: white; }
        .badge-internacional { background: #8b5cf6; color: white; }
        
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }
        .logo {
            display: flex;
            align-items: center;
            gap: 16px;
        }
        .logo-box {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, #fbbf24 0%, #d4af37 100%);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .btn-voltar {
            padding: 10px 20px;
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.3);
            color: white;
            border-radius: 8px;
            text-decoration: none;
            font-size: 14px;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Header -->
        <div class="header">
            <div class="logo">
                <div class="logo-box">📺</div>
                <div>
                    <h1 style="margin: 0; font-size: 28px; font-weight: bold;">TV VOZ DE BRASÍLIA</h1>
                    <p style="margin: 0; color: #fbbf24; font-size: 14px;">40 ANOS DE HISTÓRIA</p>
                </div>
            </div>
            <a href="index.html" class="btn-voltar">← Voltar ao Site</a>
        </div>

        <!-- Player de Vídeo -->
        <div class="video-container">
            <div id="player"></div>
        </div>

        <!-- Filtros -->
        <div class="filters">
            <button class="filter-btn destaque" onclick="filtrar('empresarial')">🏢 EMPRESARIAL</button>
            <button class="filter-btn" onclick="filtrar('politica')">🏛️ Política</button>
            <button class="filter-btn" onclick="filtrar('internacional')">🌍 Internacional</button>
            <button class="filter-btn" onclick="filtrar('todas')">Todas</button>
        </div>

        <!-- Playlist -->
        <div class="playlist" id="playlist"></div>
    </div>

    <script>
        // Lista de vídeos - ADICIONE OS IDs REAIS DOS VÍDEOS DO YOUTUBE
        const videos = [
            // EMPRESARIAL
            { id: '5QWMLQjrV4c', title: 'Instituto de Medicina da Visão', category: 'empresarial' },
            { id: 'b5t8TEEJdiU', title: 'Andrezza Bentes - Kumon', category: 'empresarial' },
            { id: 'tB84ssWNLYg', title: 'Thiago Manzoni - Empresarial', category: 'empresarial' },
            
            // POLÍTICA
            { id: 'mFX7ZEVbjrI', title: 'Igor Popov', category: 'politica' },
            { id: 'rkLjp5Loue8', title: 'Senador Dr. Hiran', category: 'politica' },
            { id: 'SWgHKS_i1UM', title: 'Representante ONU', category: 'politica' },
            
            // INTERNACIONAL
            { id: '8FBjQfoH8o8', title: 'Embaixadora do Egito', category: 'internacional' },
            { id: 'AugustoCarvalho', title: 'Augusto Carvalho - ANABB', category: 'internacional' }
        ];

        let currentCategory = 'empresarial';
        let currentIndex = 0;
        let player;
        let filteredVideos = [...videos];

        // Carrega API do YouTube
        const tag = document.createElement('script');
        tag.src = 'https://www.youtube.com/iframe_api';
        const firstScriptTag = document.getElementsByTagName('script')[0];
        firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);

        function onYouTubeIframeAPIReady() {
            player = new YT.Player('player', {
                height: '100%',
                width: '100%',
                videoId: filteredVideos[0].id,
                playerVars: {
                    'autoplay': 1,
                    'controls': 1,
                    'rel': 0
                },
                events: {
                    'onReady': onPlayerReady,
                    'onStateChange': onPlayerStateChange
                }
            });
            filtrar('empresarial');
        }

        function onPlayerReady(event) {
            player.playVideo();
        }

        function onPlayerStateChange(event) {
            if (event.data === YT.PlayerState.ENDED) {
                // Toca o próximo vídeo automaticamente
                currentIndex = (currentIndex + 1) % filteredVideos.length;
                player.loadVideoById(filteredVideos[currentIndex].id);
                renderPlaylist();
            }
        }

        function filtrar(categoria) {
            currentCategory = categoria;
            
            // Atualiza botões
            document.querySelectorAll('.filter-btn').forEach(btn => {
                btn.classList.remove('active');
                if (btn.textContent.toLowerCase().includes(categoria) || 
                    (categoria === 'todas' && btn.textContent.includes('Todas'))) {
                    btn.classList.add('active');
                }
            });

            // Filtra vídeos
            if (categoria === 'todas') {
                filteredVideos = [...videos];
            } else {
                filteredVideos = videos.filter(v => v.category === categoria);
            }

            // Toca o primeiro vídeo da categoria
            if (filteredVideos.length > 0) {
                currentIndex = 0;
                player.loadVideoById(filteredVideos[0].id);
            }
            
            renderPlaylist();
        }

        function renderPlaylist() {
            const playlistEl = document.getElementById('playlist');
            playlistEl.innerHTML = filteredVideos.map((video, index) => {
                const badges = {
                    'empresarial': '<span class="badge badge-empresarial">EMPRESARIAL</span>',
                    'politica': '<span class="badge badge-politica">POLÍTICA</span>',
                    'internacional': '<span class="badge badge-internacional">INTERNACIONAL</span>'
                };
                
                return `
                <div class="video-item ${index === currentIndex ? 'active' : ''}" onclick="tocarVideo(${index})">
                    <img src="https://img.youtube.com/vi/${video.id}/mqdefault.jpg" alt="${video.title}">
                    <div style="flex: 1;">
                        ${badges[video.category]}
                        <h3>${video.title}</h3>
                        <p>${index === currentIndex ? '▶ Tocando agora' : 'Clique para assistir'}</p>
                    </div>
                </div>
            `}).join('');
        }

        function tocarVideo(index) {
            currentIndex = index;
            player.loadVideoById(filteredVideos[currentIndex].id);
            renderPlaylist();
        }
    </script>
</body>
</html>
